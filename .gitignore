# Laravel-specific ignores
vendor/
storage/
bootstrap/cache/
public/storage
.env
.env.*
!.env.example

# Database migrations (keep the migration files themselves)
# But ignore any backup or temporary migration files
*_backup.sql
*_temp.sql
*.sql.bak

# PHP specific
*.php~
*.swp
.php_cs.cache

# Logs
*.log
storage/logs/

# IDE
.vscode/
.idea/
*.swo
*.swp

# OS
.DS_Store
Thumbs.db

# Tests
.phpunit.result.cache
coverage/
```